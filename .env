# DVAIA - Environment Configuration Example
# Copy this file to .env and customize as needed

# ============================================================
# Application Configuration (recommended values)
# ============================================================

# Flask server port
PORT=5000

# Default LLM model
DEFAULT_MODEL=ollama:llama3.2

# Agentic panel: thinking model for CoT/reasoning
# Use a model that supports Ollama "think" (e.g. qwen3:0.6b, deepseek-r1:8b)
AGENTIC_MODEL=qwen3:0.6b

# Document Injection vision mode — image bytes to VLM (not OCR text)
VISION_MODEL=ollama:qwen2.5vl:7b

# Document Injection audio transcription — local Whisper via faster-whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD_FILTER=false
WHISPER_NO_SPEECH_THRESHOLD=0.35
WHISPER_GAIN_BOOST_DB=15
WHISPER_MULTI_PASS=true
WHISPER_FALLBACK_GOOGLE=false

# Ollama host URL (local dev). Docker Compose overrides to http://ollama:11434
OLLAMA_HOST=http://localhost:11480

# Embedding backend and model for RAG
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# Security (REQUIRED for production)
# ============================================================

# Flask secret key for sessions — generate your own before deploying
# Generate with: openssl rand -hex 32
#SECRET_KEY=your-secret-key-here

# ============================================================
# Storage Paths (Docker uses /tmp by default)
# ============================================================

# Local dev paths (uncomment for non-Docker runs):
#DATABASE_URI=data/app.db
#UPLOAD_DIR=data/uploads
#PAYLOADS_OUTPUT_DIR=data/payloads/generate

# Docker paths (used when running via docker compose):
DATABASE_URI=/tmp/app.db
UPLOAD_DIR=/tmp/uploads
PAYLOADS_OUTPUT_DIR=/tmp/payloads/generate

# ============================================================
# Qdrant Vector Database (for RAG features)
# ============================================================

# Local dev. Docker Compose sets QDRANT_HOST=qdrant internally
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_chunks

# Qdrant API key (optional, for Qdrant Cloud only)
#QDRANT_API_KEY=

# ============================================================
# Notes
# ============================================================
#
# - Recommended values above match core/config.py defaults
# - Copy to .env and adjust for your setup
# - Docker Compose sets OLLAMA_HOST and QDRANT_HOST for containers
# - Keep secrets (SECRET_KEY) in .env, not in version control
# - See README.md for full documentation


